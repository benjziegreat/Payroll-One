{
  "name": "payroll-one",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "local:db:init": "node local-server/scripts/init-db.js",
    "local:certs": "mkcert -install && mkcert -key-file local-server/certs/key.pem -cert-file local-server/certs/cert.pem localhost 127.0.0.1 ::1",
    "build:local": "ng build --configuration development",
    "serve:https": "npm run build:local && node local-server/index.js",
    "tunnel:start": "node local-server/scripts/tunnel.js start",
    "tunnel:stop": "node local-server/scripts/tunnel.js stop",
    "tunnel:status": "node local-server/scripts/tunnel.js status"
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@supabase/supabase-js": "^2.108.2",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "face-api.js": "^0.22.2",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.22.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
